WORKER_BIND_HOST=0.0.0.0
WORKER_BIND_PORT=8080
WORKER_PROVIDER=playerok
WORKER_STORAGE_PATH=./data/worker-state.sqlite3

WORKER_API_SERVICE_AUTH_ENABLED=true
WORKER_API_SERVICE_AUTH_ACCEPTED_TOKENS=worker-token-a,worker-token-b
INTERNAL_API_SERVICE_AUTH_ACCEPTED_TOKENS=internal-token-a,internal-token-b

WORKER_PROXY_CREDENTIALS_ENCRYPTION_KEY=replace-with-worker-proxy-secrets-key
WORKER_MARKETPLACE_AUTH_ENCRYPTION_KEY=replace-with-worker-marketplace-auth-key

# Optional explicit single-tenant binding (обычно задаётся Accounts Manager autospawn).
DDCRM_WORKER_ACCOUNT_ID=
PLAYEROK_WORKER_ACCOUNT_ID=

# Optional bootstrap credentials for direct Playerok initialization.
PLAYEROK_TOKEN=
PLAYEROK_DDG5=
PLAYEROK_COOKIES=
PLAYEROK_USER_AGENT=
PLAYEROK_REQUESTS_TIMEOUT=30
